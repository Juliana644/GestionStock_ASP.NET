@model GestionStock.Models.Categorie
@{
    ViewData["Title"] = "Détails de la catégorie";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0"> @Model.Nom</h4>
            </div>
            <div class="card-body">
                <p><strong>Description :</strong> @Model.Description</p>
                <p><strong>Nombre de produits :</strong>
                    <span class="badge bg-primary">@Model.Produits.Count</span>
                </p>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
                @if (User.Identity != null && User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Supprimer</a>
                }
            </div>
        </div>

        @if (Model.Produits.Any())
        {
            <div class="card">
                <div class="card-header bg-dark text-white">
                    Produits dans cette catégorie
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Référence</th>
                                <th>Nom</th>
                                <th>Prix</th>
                                <th>Stock</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var produit in Model.Produits)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@produit.Reference</span></td>
                                    <td>@produit.Nom</td>
                                    <td>@produit.PrixUnitaire.ToString("N0") FCFA</td>
                                    <td>@produit.QuantiteEnStock</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>