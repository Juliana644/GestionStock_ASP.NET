@model GestionStock.Models.ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"> Une erreur est survenue</h4>
            </div>
            <div class="card-body">
                <p>ID de la requête : <code>@Model?.RequestId</code></p>
            </div>
            <div class="card-footer">
                <a asp-controller="Home" asp-action="Index" class="btn btn-dark">← Retour à l'accueil</a>
            </div>
        </div>
    </div>
</div>