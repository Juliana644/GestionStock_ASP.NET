@model GestionStock.Models.Produit
@{
    ViewData["Title"] = "Modifier le produit";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-warning">
                <h4 class="mb-0">✏️ Modifier : @Model.Nom</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="DateAjout" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Reference" class="form-label"></label>
                            <input asp-for="Reference" class="form-control" />
                            <span asp-validation-for="Reference" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Nom" class="form-label"></label>
                            <input asp-for="Nom" class="form-control" />
                            <span asp-validation-for="Nom" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PrixUnitaire" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="PrixUnitaire" class="form-control" />
                                <span class="input-group-text">FCFA</span>
                            </div>
                            <span asp-validation-for="PrixUnitaire" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="QuantiteEnStock" class="form-label"></label>
                            <input asp-for="QuantiteEnStock" class="form-control" />
                            <span asp-validation-for="QuantiteEnStock" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="SeuilAlerte" class="form-label"></label>
                            <input asp-for="SeuilAlerte" class="form-control" />
                            <span asp-validation-for="SeuilAlerte" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategorieId" class="form-label"></label>
                            <select asp-for="CategorieId" asp-items="ViewBag.CategorieId"
                                    class="form-select">
                                <option value="">-- Choisir une catégorie --</option>
                            </select>
                            <span asp-validation-for="CategorieId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="Actif" type="checkbox" class="form-check-input" />
                                <label asp-for="Actif" class="form-check-label">Actif</label>
                            </div>
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Enregistrer les modifications</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>