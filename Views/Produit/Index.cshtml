@model IEnumerable<GestionStock.Models.Produit>
@{
    ViewData["Title"] = "Produits";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Produits</h2>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <a asp-action="Create" class="btn btn-primary">+ Nouveau produit</a>
    }
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-2">
            <div class="col-md-4">
                <input type="text" name="recherche" value="@ViewBag.Recherche"
                       class="form-control" placeholder="Rechercher par nom ou référence..." />
            </div>
            <div class="col-md-3">
                <select name="categorieId" class="form-select"
                        asp-items="ViewBag.Categories">
                    <option value="">-- Toutes les catégories --</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-center">
                <div class="form-check">
                    <input type="checkbox" name="stockFaible" value="true"
                           class="form-check-input" id="stockFaible"
                           @(ViewBag.StockFaible == true ? "checked" : "") />
                    <label class="form-check-label" for="stockFaible">
                        Stock faible seulement
                    </label>
                </div>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filtrer</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Aucun produit trouvé.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Référence</th>
                        <th>Nom</th>
                        <th>Catégorie</th>
                        <th>Prix</th>
                        <th>Stock</th>
                        <th>Actif</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var produit in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@produit.Reference</span></td>
                            <td>@produit.Nom</td>
                            <td>@produit.Categorie?.Nom</td>
                            <td>@produit.PrixUnitaire.ToString("N0") FCFA</td>
                            <td>
                                @if (produit.QuantiteEnStock <= produit.SeuilAlerte)
                                {
                                    <span class="badge bg-danger">@produit.QuantiteEnStock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@produit.QuantiteEnStock</span>
                                }
                            </td>
                            <td>
                                @if (produit.Actif)
                                {
                                    <span class="badge bg-success">Oui</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Non</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@produit.Id"
                                   class="btn btn-sm btn-outline-info">Détails</a>
                                @if (User.Identity != null && User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@produit.Id"
                                       class="btn btn-sm btn-outline-warning">Modifier</a>
                                    <a asp-action="Delete" asp-route-id="@produit.Id"
                                       class="btn btn-sm btn-outline-danger">Supprimer</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}