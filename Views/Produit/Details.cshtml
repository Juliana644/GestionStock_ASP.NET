@model Produit
@{
    ViewData["Title"] = "Détails du produit";
}

<h1>@Model.Nom</h1>
<a asp-action="Index">← Retour à la liste</a> |
<a asp-action="Edit" asp-route-id="@Model.Id">Modifier</a>

<hr />

<dl>
    <dt>Référence</dt>
    <dd>@Model.Reference</dd>

    <dt>Catégorie</dt>
    <dd>@Model.Categorie?.Nom</dd>

    <dt>Description</dt>
    <dd>@Model.Description</dd>

    <dt>Prix unitaire</dt>
    <dd>@Model.PrixUnitaire.ToString("N0") FCFA</dd>

    <dt>Quantité en stock</dt>
    <dd>@Model.QuantiteEnStock</dd>

    <dt>Seuil d'alerte</dt>
    <dd>@Model.SeuilAlerte</dd>

    <dt>Date d'ajout</dt>
    <dd>@Model.DateAjout.ToString("dd/MM/yyyy")</dd>

    <dt>Actif</dt>
    <dd>@(Model.Actif ? "Oui" : "Non")</dd>
</dl>

<hr />

<h2>Derniers mouvements de stock</h2>

@if (!Model.MouvementsStock.Any())
{
    <p>Aucun mouvement enregistré.</p>
}
else
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Quantité</th>
                <th>Motif</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var mouvement in Model.MouvementsStock)
            {
                <tr>
                    <td>@mouvement.DateMouvement.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@mouvement.Type</td>
                    <td>@mouvement.Quantite</td>
                    <td>@mouvement.Motif</td>
                </tr>
            }
        </tbody>
    </table>
}