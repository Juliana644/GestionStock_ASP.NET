@model GestionStock.Models.Produit
@{
    ViewData["Title"] = "Détails du produit";
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">@Model.Nom</h4>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th>Référence</th>
                        <td><span class="badge bg-secondary">@Model.Reference</span></td>
                    </tr>
                    <tr>
                        <th>Catégorie</th>
                        <td>@Model.Categorie?.Nom</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>@Model.Description</td>
                    </tr>
                    <tr>
                        <th>Prix unitaire</th>
                        <td><strong>@Model.PrixUnitaire.ToString("N0") FCFA</strong></td>
                    </tr>
                    <tr>
                        <th>Quantité en stock</th>
                        <td>
                            @if (Model.QuantiteEnStock <= Model.SeuilAlerte)
                            {
                                <span class="badge bg-danger fs-6">@Model.QuantiteEnStock</span>
                            }
                            else
                            {
                                <span class="badge bg-success fs-6">@Model.QuantiteEnStock</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Seuil d'alerte</th>
                        <td>@Model.SeuilAlerte</td>
                    </tr>
                    <tr>
                        <th>Date d'ajout</th>
                        <td>@Model.DateAjout.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th>Statut</th>
                        <td>
                            @if (Model.Actif)
                            {
                                <span class="badge bg-success">Actif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactif</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
                @if (User.Identity != null && User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Supprimer</a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-dark text-white">
                Derniers mouvements de stock
            </div>
            <div class="card-body p-0">
                @if (!Model.MouvementsStock.Any())
                {
                    <p class="p-3 text-muted mb-0">Aucun mouvement enregistré.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Qté</th>
                                <th>Motif</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.MouvementsStock)
                            {
                                <tr>
                                    <td>@m.DateMouvement.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (m.Type.ToString() == "Entree")
                                        {
                                            <span class="badge bg-success">Entrée</span>
                                        }
                                        else if (m.Type.ToString() == "Sortie")
                                        {
                                            <span class="badge bg-danger">Sortie</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Ajustement</span>
                                        }
                                    </td>
                                    <td>@m.Quantite</td>
                                    <td>@m.Motif</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>